# Database
DATABASE_URL=postgresql://sync_user:sync_password@localhost:5432/sync_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=900s
JWT_REFRESH_EXPIRATION=604800s

# OAuth - Notion
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_INTERNAL_INTEGRATION_TOKEN=

# OAuth - Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OAuth - Microsoft
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# OAuth - Todoist
TODOIST_OAUTH_CLIENT_ID=
TODOIST_OAUTH_CLIENT_SECRET=

# App
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-for-tokens

# Logging
LOG_LEVEL=info

# AWS (optional, for backups/storage)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
